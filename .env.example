# --- Runtime ---
NODE_ENV=production
PORT=5000

# --- Database (Neon / Supabase / Render Postgres) ---
# DATABASE_URL: pooled connection (PgBouncer on port 6543 for Supabase)
# DIRECT_URL:   direct connection (port 5432) — used by Prisma migrate
DATABASE_URL=postgresql://user:pass@host:6543/db?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://user:pass@host:5432/db

# --- Auth ---
# Random string, >= 12 chars. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# --- Cloudinary (file uploads) ---
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
